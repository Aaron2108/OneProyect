# === Aplicación ===
NODE_ENV=development
PORT=3000

# === Base de datos (PostgreSQL) ===
# Coincide con las credenciales de docker-compose.yml para desarrollo local
DATABASE_URL="postgresql://whatsflow:whatsflow_dev@localhost:5432/whatsflow?schema=public"

# === Redis (colas BullMQ) ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === Autenticación ===
# Genera un secreto fuerte para producción: `openssl rand -base64 48`
JWT_SECRET=cambia_esto_por_un_secreto_fuerte_en_produccion
JWT_EXPIRES_IN=1d

# === WhatsApp / Meta Cloud API ===
# Se obtienen al registrar la app en https://developers.facebook.com
WHATSAPP_VERIFY_TOKEN=token_de_verificacion_del_webhook
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=

# === IA (Claude / Anthropic) ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
# Guarda de costo (NFR): máximo de llamadas a la IA por conversación en la ventana
AI_MAX_CALLS_PER_CONVERSATION_PER_HOUR=20
