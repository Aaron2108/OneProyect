// WhatsFlow AI — esquema de datos del MVP (Fase 1)
// Multi-tenancy: esquema compartido, `tenantId` en todas las tablas de negocio.
// Sin pgvector en el MVP (memoria vectorial diferida a Fase 4, ver docs/DECISIONS.md).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  OWNER
  AGENT
}

enum MessageDirection {
  INBOUND // del cliente final hacia la empresa
  OUTBOUND // de la empresa/IA hacia el cliente final
}

enum MessageSender {
  CONTACT // lo escribió el cliente final
  AI // lo generó el agente de IA
  HUMAN // lo escribió un miembro del equipo
}

// Quién atiende la conversación (RF-11: handoff humano)
enum ConversationHandler {
  AI
  HUMAN
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ReminderStatus {
  PENDING
  SENT
  CANCELLED
}

// RF-12: opt-in del contacto
enum ConsentStatus {
  GRANTED
  DENIED
  UNKNOWN
}

// ---------------------------------------------------------------------------
// Modelos
// ---------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(uuid())
  name      String
  // ID del número de WhatsApp en Meta — enruta cada webhook entrante a su tenant
  whatsappPhoneNumberId String? @unique @map("whatsapp_phone_number_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  contacts      Contact[]
  conversations Conversation[]
  appointments  Appointment[]
  reminders     Reminder[]
  quickReplies  QuickReply[]
  googleCalendarIntegration GoogleCalendarIntegration?
  googleCalendarSyncJobs    GoogleCalendarSyncJob[]
  aiContextMemories         AiContextMemory[]

  @@map("tenants")
}

// Fase 3 (integraciones): conexión de UN calendario de Google por tenant (lo
// conecta el OWNER). Sincronización de una sola vía (WhatsFlow → Google) — ver
// docs/DECISIONS.md. Tokens cifrados en reposo (AES-256-GCM, ver
// src/common/crypto.util.ts); nunca se guardan en claro.
model GoogleCalendarIntegration {
  id                   String   @id @default(uuid())
  tenantId             String   @unique @map("tenant_id")
  googleAccountEmail   String   @map("google_account_email")
  googleCalendarId     String   @default("primary") @map("google_calendar_id")
  accessToken          String   @map("access_token") // cifrado
  refreshToken         String   @map("refresh_token") // cifrado
  accessTokenExpiresAt DateTime @map("access_token_expires_at")
  connectedByUserId    String   @map("connected_by_user_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("google_calendar_integrations")
}

// Cola de reintentos para la sincronización con Google Calendar: si crear/
// actualizar/borrar el evento falla (red, token, rate limit de Google), en vez
// de abandonar en silencio se guarda aquí con backoff exponencial. Un job por
// cita (@unique) — cada intento reconcilia el estado completo de la cita, así
// que no hace falta encolar más de uno a la vez. Ver GoogleCalendarSyncService.
model GoogleCalendarSyncJob {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  appointmentId String   @unique @map("appointment_id")
  attempts      Int      @default(0)
  nextAttemptAt DateTime @map("next_attempt_at")
  lastError     String?  @map("last_error")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([nextAttemptAt])
  @@map("google_calendar_sync_jobs")
}

// Respuestas rápidas: plantillas de mensaje reutilizables del equipo.
model QuickReply {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  title     String
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("quick_replies")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  email        String
  // Nulo si la cuenta se creó con "Continuar con Google" y nunca puso una
  // contraseña propia (ver auth/google-auth.service.ts) — no reemplaza al login
  // por contraseña, es una alternativa.
  passwordHash String?  @map("password_hash")
  // `sub` de Google (identificador estable de la cuenta), si se vinculó.
  googleId     String?  @unique @map("google_id")
  name         String
  role         UserRole @default(AGENT)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Contact {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  phone     String // número de WhatsApp del cliente final (E.164)
  name      String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  appointments  Appointment[]
  reminders     Reminder[]
  consent       ContactConsent?
  aiContextMemories AiContextMemory[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("contacts")
}

model Conversation {
  id        String              @id @default(uuid())
  tenantId  String              @map("tenant_id")
  contactId String              @map("contact_id")
  status    ConversationStatus  @default(OPEN)
  handledBy ConversationHandler @default(AI) @map("handled_by") // RF-11: quién responde ahora
  // Contador denormalizado de mensajes entrantes sin leer por el equipo: lo
  // incrementa el worker al recibir un entrante y se pone a 0 al abrir el hilo.
  // Denormalizado para no recalcularlo en cada listado (escala).
  unreadCount Int               @default(0) @map("unread_count")
  // RF-10: la ventana de 24h se calcula desde el último mensaje entrante
  lastInboundAt DateTime?       @map("last_inbound_at")
  lastMessageAt DateTime?       @map("last_message_at")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact  Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages Message[]
  notes    ConversationNote[]

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@index([tenantId, status, lastMessageAt])
  @@map("conversations")
}

// Notas internas del equipo sobre una conversación (privadas, no se envían al cliente).
model ConversationNote {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  conversationId String   @map("conversation_id")
  authorId       String   @map("author_id")
  authorName     String   @map("author_name") // denormalizado para que el nombre sobreviva
  body           String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("conversation_notes")
}

model Message {
  id             String           @id @default(uuid())
  tenantId       String           @map("tenant_id")
  conversationId String           @map("conversation_id")
  direction      MessageDirection
  sender         MessageSender
  // ID del mensaje en Meta — único por tenant para deduplicar reenvíos (guarda NFR)
  whatsappMessageId String?       @map("whatsapp_message_id")
  type           String           @default("text") // text | template | image | ...
  content        String
  createdAt      DateTime         @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([tenantId, whatsappMessageId])
  @@index([conversationId, createdAt])
  @@map("messages")
}

model Appointment {
  id          String            @id @default(uuid())
  tenantId    String            @map("tenant_id")
  contactId   String            @map("contact_id")
  title       String
  scheduledAt DateTime          @map("scheduled_at")
  status      AppointmentStatus @default(SCHEDULED)
  notes       String?
  // ID del evento en Google Calendar si el tenant tiene la integración conectada
  // (Fase 3); null si no está sincronizada o si el tenant no la usa.
  googleEventId String?         @map("google_event_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact   Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  reminders Reminder[]
  googleCalendarSyncJob GoogleCalendarSyncJob?

  @@index([tenantId])
  @@index([tenantId, scheduledAt])
  @@map("appointments")
}

model Reminder {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  contactId     String         @map("contact_id")
  appointmentId String?        @map("appointment_id")
  message       String
  remindAt      DateTime       @map("remind_at")
  status        ReminderStatus @default(PENDING)
  // Despacho a prueba de concurrencia/escala: `nextAttemptAt` actúa como lease
  // (claim atómico entre instancias) y como backoff; `attempts` cuenta los
  // envíos fallidos para acotar reintentos. Ver ReminderDispatchService.
  attempts      Int            @default(0)
  nextAttemptAt DateTime?      @map("next_attempt_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status, remindAt])
  @@index([status, nextAttemptAt])
  @@map("reminders")
}

// RF-12: consentimiento (opt-in) del contacto para recibir mensajes
model ContactConsent {
  id         String        @id @default(uuid())
  tenantId   String        @map("tenant_id")
  contactId  String        @unique @map("contact_id")
  status     ConsentStatus @default(UNKNOWN)
  source     String? // cómo se obtuvo el opt-in (ej. "primer mensaje entrante")
  grantedAt  DateTime?     @map("granted_at")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("contact_consent")
}

// Fase 4 (IA y automatizaciones): memoria de contexto entre conversaciones,
// por contacto. Se guarda un resumen (generado por la IA al cerrar una
// conversación, ver ConversationsService) junto con su embedding; al
// responder, la IA recupera los resúmenes más similares al mensaje actual del
// mismo contacto (nunca cruza tenants ni contactos) — así recuerda algo más
// allá de la ventana de contexto de la conversación en curso. Ver
// docs/DECISIONS.md (2026-07-23).
//
// `embedding` es `Unsupported` porque Prisma Client no representa el tipo
// `vector` de pgvector: se inserta/consulta con SQL crudo
// (AiContextMemoryService), nunca con el Prisma Client normal. `content` se
// cifra en reposo igual que Message.content/ConversationNote.body (PII).
model AiContextMemory {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  contactId      String   @map("contact_id")
  conversationId String?  @map("conversation_id")
  content        String // resumen cifrado (AES-256-GCM, ver common/pii-crypto.service.ts)
  embedding      Unsupported("vector(512)")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId, contactId])
  @@map("ai_context_memory")
}
